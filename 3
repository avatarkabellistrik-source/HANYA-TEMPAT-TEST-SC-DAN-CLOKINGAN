<?php
/**
 * Script interaktif untuk mengubah permission directory plugins menjadi 555
 * Path: /www/wwwroot/jurnal.radenfatah.ac.id/plugins
 */

$defaultDirectory = '/www/wwwroot/jurnal.radenfatah.ac.id/plugins';
$message = '';

// Proses form jika disubmit
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $directory = isset($_POST['directory']) ? trim($_POST['directory']) : $defaultDirectory;
    $recursive = isset($_POST['recursive']);
    $permission = 0555;
    
    if (!empty($directory)) {
        // Cek directory
        if (!is_dir($directory)) {
            $message = "Error: Directory '$directory' tidak ditemukan!";
        } else {
            // Proses chmod
            $results = [];
            $perm = substr(sprintf('%o', $permission), -4);
            
            // Ubah permission directory utama
            if (chmod($directory, $permission)) {
                $results[] = "✓ Permission '$directory' diubah menjadi $perm";
            } else {
                $results[] = "✗ Gagal mengubah permission '$directory'";
            }
            
            // Jika recursive, proses sub-directory
            if ($recursive) {
                $iterator = new RecursiveIteratorIterator(
                    new RecursiveDirectoryIterator($directory, RecursiveDirectoryIterator::SKIP_DOTS),
                    RecursiveIteratorIterator::SELF_FIRST
                );
                
                $count = 0;
                foreach ($iterator as $item) {
                    if ($item->isDir()) {
                        $subDir = $item->getPathname();
                        if (chmod($subDir, $permission)) {
                            $results[] = "✓ Permission '$subDir' diubah menjadi $perm";
                            $count++;
                        } else {
                            $results[] = "✗ Gagal mengubah permission '$subDir'";
                        }
                    }
                }
                $results[] = "\nTotal sub-directory yang diproses: $count";
            }
            
            $message = implode("\n", $results);
        }
    } else {
        $message = "Error: Directory path tidak boleh kosong!";
    }
}

// Ambil informasi permission saat ini
$currentPerm = '';
if (is_dir($defaultDirectory)) {
    $currentPerm = substr(sprintf('%o', fileperms($defaultDirectory)), -4);
}
