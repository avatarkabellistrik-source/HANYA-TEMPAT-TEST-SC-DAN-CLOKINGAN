// Konfigurasi - GANTI CHAT ID NYA!
$token = '8802669146:AAFtVVVFXrxl6J7bbPGx2UUwmv4Hl_Q63OU';
$chatId = '7470536859'; // GANTI DENGAN CHAT ID YANG BENAR!

echo "<h1>📱 TEST TELEGRAM</h1>";

// STEP 1: CEK TOKEN
echo "<h3>1. Cek Token Bot</h3>";
$url = "https://api.telegram.org/bot{$token}/getMe";
$response = file_get_contents($url);
$data = json_decode($response, true);

if ($data && $data['ok']) {
    echo "✅ Token VALID<br>";
    echo "Bot: @" . $data['result']['username'] . "<br><br>";
} else {
    die("❌ Token INVALID! Cek token Anda.");
}

// STEP 2: CEK CHAT ID
echo "<h3>2. Cek Chat ID</h3>";
$url = "https://api.telegram.org/bot{$token}/getUpdates";
$response = file_get_contents($url);
$data = json_decode($response, true);

if ($data && !empty($data['result'])) {
    $last = end($data['result']);
    $chatIdReal = $last['message']['chat']['id'] ?? null;
    echo "✅ Chat ID ditemukan: <strong>{$chatIdReal}</strong><br>";
    echo "Ganti chat_id di kode dengan: <strong>{$chatIdReal}</strong><br><br>";
    
    // Pakai chat ID yang real
    $chatId = $chatIdReal;
} else {
    echo "⚠️ BELUM ADA CHAT ID!<br>";
    echo "Langkah: <br>";
    echo "1. Buka Telegram<br>";
    echo "2. Cari bot: @" . $data['result']['username'] . "<br>";
    echo "3. Kirim pesan: <strong>/start</strong><br>";
    echo "4. Refresh halaman ini<br><br>";
}

// STEP 3: KIRIM PESAN
if (!empty($chatId) && is_numeric($chatId)) {
    echo "<h3>3. Kirim Pesan Test</h3>";
    
    $message = "✅ TEST SUKSES!\n";
    $message .= "Waktu: " . date('Y-m-d H:i:s') . "\n";
    $message .= "IP: " . ($_SERVER['REMOTE_ADDR'] ?? 'CLI') . "\n";
    $message .= "Server: " . ($_SERVER['SERVER_NAME'] ?? 'localhost');
    
    $url = "https://api.telegram.org/bot{$token}/sendMessage";
    $data = [
        'chat_id' => $chatId,
        'text' => $message,
        'disable_web_page_preview' => true
    ];
    
    $ch = curl_init();
    curl_setopt($ch, CURLOPT_URL, $url);
    curl_setopt($ch, CURLOPT_POST, true);
    curl_setopt($ch, CURLOPT_POSTFIELDS, http_build_query($data));
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
    curl_setopt($ch, CURLOPT_TIMEOUT, 10);
    
    $result = curl_exec($ch);
    $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);
    
    if ($httpCode == 200) {
        echo "✅ <strong style='color:green'>PESAN TERKIRIM! Cek Telegram Anda!</strong>";
    } else {
        echo "❌ GAGAL! HTTP Code: {$httpCode}<br>";
        echo "Error: " . htmlspecialchars($result);
    }
} else {
    echo "<h3>3. Kirim Pesan Test</h3>";
    echo "❌ Chat ID tidak valid!";
}

